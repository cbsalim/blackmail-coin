NEXT_PUBLIC_ONCHAINKIT_API_KEY=your_onchainkit_api_key
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Required for server-side contract reads and resolve() writes
RPC_URL=
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS
ORACLE_PRIVATE_KEY=0x

# Required for Strava OAuth
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Optional. If omitted, the app uses <current-origin>/api/strava/callback
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback

# Optional. If set, /api/cron/verify expects Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Optional seed data for the in-memory Strava connection store.
# For demos, prefer preloading the demo wallet here and skipping live OAuth.
# Example:
# STRAVA_CONNECTIONS_JSON=[{"wallet":"0x1234567890123456789012345678901234567890","stravaId":12345,"accessToken":"access-token","refreshToken":"refresh-token","expiresAt":1893456000}]
STRAVA_CONNECTIONS_JSON=[]
